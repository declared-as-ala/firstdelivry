# === Database (required) ===
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/logiflow

# === Auth (required) ===
# Generate: openssl rand -base64 32
AUTH_SECRET=replace_with_secure_random_secret
# In production set to your deployed URL (e.g. https://navex.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# === First Delivery Group (server-side only) ===
FIRST_DELIVERY_API_BASE=https://www.firstdeliverygroup.com/api/v2
FIRST_DELIVERY_TOKEN=
# Auto-push to First Delivery when delivery company name contains this string (case-insensitive)
FIRST_DELIVERY_AUTO_PUSH_LABEL=firstdelivery

# === Navex.tn (server-side only) — a SEPARATE carrier from First Delivery above.
# "Envoi d'un colis" (creation) is the only endpoint documented/implemented so far.
# Récupération / Récupération Multiple / Liste colis en attente / Suppression all
# need their own request+response docs before they can be wired up. ===
NAVEX_TN_API_BASE=https://app.navex.tn/api
NAVEX_TN_ADD_TOKEN=
NAVEX_TN_STATUS_TOKEN=
NAVEX_TN_DELETE_TOKEN=

# === Cron (optional) ===
# Bearer secret protecting POST /api/cron/navex-sync
CRON_SECRET=replace_with_secure_secret
